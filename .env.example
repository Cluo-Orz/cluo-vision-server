# Cluo Vision Server 环境变量配置
# 复制此文件为 .env 并修改对应值

# 用户/组 ID (运行 Docker 的用户)
PUID=1000
PGID=1000

# 时区
TZ=Asia/Shanghai

# NAS 媒体存储根目录 (按实际情况修改)
MEDIA_ROOT=/nas/media

# Jellyfin 访问 URL (局域网内访问地址，留空则自动)
JELLYFIN_URL=

# ---- 以下为各服务 API Key (部署后从 WebUI 获取) ----

# Sonarr API Key (Sonarr → Settings → General)
SONARR_API_KEY=

# Radarr API Key (Radarr → Settings → General)
RADARR_API_KEY=

# cluo-vision-server JWT 签名密钥 (随机字符串)
JWT_SECRET=change-me-to-a-random-string
