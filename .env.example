# Cluo Vision Server 环境变量配置
# 复制此文件为 .env 并修改对应值

# 用户/组 ID (运行 Docker 的用户)
PUID=1000
PGID=1000

# 时区
TZ=Asia/Shanghai

# NAS 媒体存储根目录 (按实际情况修改)
MEDIA_ROOT=/nas/media

# Jellyfin 对外发布 URL (给 Jellyfin 自身使用；局域网留空通常即可)
JELLYFIN_URL=

# cluo-server / BFF
CLUO_SERVER_PORT=3000
CLUO_TOKEN_SECRET=change-me-to-a-random-string
CLUO_TOKEN_TTL_SECONDS=1209600
CLUO_DOWNLOAD_SIMULATION_MS=1000
CLUO_DOWNLOAD_IMPORT_AUTOMATION_ENABLED=true
CLUO_DOWNLOAD_IMPORT_AUTOMATION_INTERVAL_MS=60000
CLUO_DOWNLOAD_IMPORT_AUTOMATION_RETRY_MS=120000

# cluo-server 在 Docker 网络内访问依赖服务的地址
CLUO_AUTO_BANGUMI_URL=http://autobangumi:7892
CLUO_QBITTORRENT_URL=http://qbittorrent:8080
CLUO_JELLYFIN_URL=http://jellyfin:8096

# 如果直接在宿主机 cd server && npm run dev，可改用下面这些本机地址：
# AUTO_BANGUMI_URL=http://127.0.0.1:7892
# QBITTORRENT_URL=http://127.0.0.1:8080
# JELLYFIN_URL=http://127.0.0.1:8096

AUTO_BANGUMI_TOKEN=
AUTO_BANGUMI_PROVIDER=mikan
CLUO_SMOKE_ANIME_QUERY=迷宫饭
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=
QBITTORRENT_API_KEY=
JELLYFIN_TOKEN=
JELLYFIN_USER_ID=
JELLYFIN_USERNAME=
JELLYFIN_PASSWORD=
JELLYFIN_DEVICE_ID=cluo-server-dev
CLUO_SMOKE_JELLYFIN_SEARCH=迷宫
CLUO_REAL_SMOKE_REQUIRE=
PLAYBACK_PROVIDER=local-dev
PLAYBACK_EXTERNAL_PLAYER_PACKAGE=
PLAYBACK_EXTERNAL_PLAYER_MIME_TYPE=video/*

# ---- 以下为各服务 API Key (部署后从 WebUI 获取) ----

# Sonarr API Key (Sonarr → Settings → General)
SONARR_API_KEY=

# Radarr API Key (Radarr → Settings → General)
RADARR_API_KEY=
