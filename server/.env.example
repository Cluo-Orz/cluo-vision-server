# cluo-server local development
# Copy to .env when running npm run dev or npm start from this directory.

HOST=127.0.0.1
PORT=3000
CLUO_DATA_DIR=./data
CLUO_TOKEN_SECRET=change-me-local-dev
CLUO_TOKEN_TTL_SECONDS=1209600
CLUO_DOWNLOAD_SIMULATION_MS=1000

AUTO_BANGUMI_URL=http://127.0.0.1:7892
AUTO_BANGUMI_TOKEN=
AUTO_BANGUMI_PROVIDER=mikan
CLUO_SMOKE_ANIME_QUERY=Dungeon Meshi

QBITTORRENT_URL=http://127.0.0.1:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=
QBITTORRENT_API_KEY=

JELLYFIN_URL=http://127.0.0.1:8096
JELLYFIN_TOKEN=
JELLYFIN_USER_ID=
JELLYFIN_USERNAME=
JELLYFIN_PASSWORD=
JELLYFIN_DEVICE_ID=cluo-server-dev
CLUO_SMOKE_JELLYFIN_SEARCH=Dungeon
CLUO_REAL_SMOKE_REQUIRE=

PLAYBACK_PROVIDER=local-dev
PLAYBACK_EXTERNAL_PLAYER_PACKAGE=
PLAYBACK_EXTERNAL_PLAYER_MIME_TYPE=video/*
